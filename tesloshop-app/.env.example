# Copiar a .env y ajustar valores secretos:
#   cp .env.example .env

# ─────── PostgreSQL ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar_por_un_secreto_seguro
POSTGRES_DB=TesloDB
POSTGRES_PUBLISH_PORT=5432
POSTGRES_CONTAINER_NAME=teslo-db

# ─────── Backend (NestJS) ─────────────────────
APP_VERSION=1.0.1
STAGE=dev
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=cambiar_por_un_secreto_seguro
DB_NAME=TesloDB
PORT=3000
BACKEND_PUBLISH_PORT=3000
BACKEND_CONTAINER_NAME=teslo-backend
HOST_API=http://localhost:3000/api
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

# ─────── Frontend (Nginx) ─────────────────────
FRONTEND_PUBLISH_PORT=80
FRONTEND_CONTAINER_NAME=teslo-frontend
